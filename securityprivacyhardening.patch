@@ -64,6 +73,12 @@ const rest: KVStore = {
   async set<T>(key: string, value: T): Promise<void> {
     await command(['SET', key, JSON.stringify(value)]);
   },
+  async setNX<T>(key: string, value: T): Promise<boolean> {
+    // Redis `SET key value NX` returns "OK" when written, nil when the
+    // key already exists. command() maps nil to null.
+    const result = await command(['SET', key, JSON.stringify(value), 'NX']);
+    return result === 'OK';
+  },
