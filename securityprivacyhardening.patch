+ * id — or a replayed/forged archive call targeting an existing id —
+ * is refused and reported as linkActive=false rather than clobbering
+ * the live moment.
  */
 export async function putMoment(moment: Moment): Promise<PutMomentResult> {
   if (!isKVConfigured) return { linkActive: false };
